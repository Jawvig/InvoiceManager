# Sets the local seed values the InvoiceManager.Seeder substitutes into
# data/seed/invoice-configurations.json. These are secrets, so they must NOT be
# committed to this repo.
#
# Usage:
#   1. Copy this file to Set-SeedEnvironment.ps1 (which is gitignored).
#   2. Replace the placeholder values below with the real drive id / billing account id.
#   3. Run it once. It sets User-scoped variables, so they persist across shells,
#      worktrees and reboots. Open a new shell afterwards for them to take effect.
#
# The real Set-SeedEnvironment.ps1 is intended to live in a private provisioning
# repo so a clean Windows machine can be set up by running it.

[Environment]::SetEnvironmentVariable(
    'InvoiceManager__Seed__DriveId', 'REPLACE_WITH_DRIVE_ID', 'User')
[Environment]::SetEnvironmentVariable(
    'InvoiceManager__Seed__BillingAccountId', 'REPLACE_WITH_BILLING_ACCOUNT_ID', 'User')

Write-Host 'Seed environment variables set at User scope. Open a new shell to use them.'
