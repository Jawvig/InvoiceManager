@page
@model InvoiceManager.AdminWeb.Pages.Configurations.IndexModel
@{ ViewData["Title"] = "Invoice configurations"; }
<section class="admin-shell">
    <div class="page-heading"><p class="eyebrow">Operations</p><h1>Invoice configurations</h1>
        <p class="summary">Manage recurring invoice expectations. Changes apply only to future expected records.</p></div>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage)) { <div class="notice">@Model.StatusMessage</div> }
    @if (!Model.HasWorkflowAuthorization) { <div class="notice warning">Workflow authorization is not captured. You may list configurations and inspect history, but configuration changes are disabled.</div> }
    <div class="actions">
        @if (Model.EditingEnabled)
        {
            <a asp-page="Create" class="primary-action">Create</a>
        }
        else
        {
            <button type="button" class="primary-action" disabled title="Capture workflow authorization before creating configurations.">Create</button>
        }
    </div>
    <div class="configuration-list">
    @foreach (var item in Model.Configurations.OrderBy(x => x.Configuration.InvoiceDescription)) {
        var configuration = item.Configuration;
        <section class="status-panel">
            <h2>@(string.IsNullOrWhiteSpace(configuration.InvoiceDescription) ? configuration.Id.Value : configuration.InvoiceDescription)</h2>
            <dl class="field-list">
                <div>
                    <dt>Configuration ID</dt>
                    <dd>@configuration.Id</dd>
                </div>
                <div>
                    <dt>Integration</dt>
                    <dd>@(configuration.IntegrationType == InvoiceManager.Core.IntegrationType.MicrosoftBilling ? "Microsoft billing" : "Microsoft 365 email")</dd>
                </div>
                <div>
                    <dt>Status</dt>
                    <dd>@(configuration.IsActive ? "Active" : "Inactive")</dd>
                </div>
                @switch (configuration.IntegrationConfiguration)
                {
                    case InvoiceManager.Core.MicrosoftBillingIntegrationConfiguration billing:
                        <div>
                            <dt>Billing account</dt>
                            <dd>
                                @(Model.BillingAccountLabels.GetValueOrDefault(billing.BillingAccountId, billing.BillingAccountId))
                                <i class="info-icon" title="Billing account ID: @billing.BillingAccountId" aria-label="Billing account ID: @billing.BillingAccountId">i</i>
                            </dd>
                        </div>
                        break;
                    case InvoiceManager.Core.GraphEmailIntegrationConfiguration email:
                        <div>
                            <dt>Sender</dt>
                            <dd>@email.SenderEmailAddress</dd>
                        </div>
                        break;
                }
                <div>
                    <dt>OneDrive folder</dt>
                    <dd>@configuration.OneDriveFolder.DriveName · @configuration.OneDriveFolder.FolderPath</dd>
                </div>
            </dl>
            <div class="actions">
                <a asp-page="History" asp-route-id="@configuration.Id.Value" asp-route-integrationType="@configuration.IntegrationType" class="secondary-action">History</a>
                @if (Model.EditingEnabled) {
                    <a asp-page="Edit" asp-route-id="@configuration.Id.Value" asp-route-integrationType="@configuration.IntegrationType" class="secondary-action">Edit</a>
                    <form method="post">
                        <input type="hidden" name="id" value="@configuration.Id.Value" /><input type="hidden" name="integrationType" value="@configuration.IntegrationType" />
                        <input type="hidden" name="etag" value="@item.ETag" /><input type="hidden" name="activate" value="@(!configuration.IsActive)" />
                        <button asp-page-handler="SetActive" class="secondary-action"
                            title="@(configuration.IsActive ? "Deactivation preserves history; outstanding records will be skipped until reactivated." : "Activation resumes processing on the next scheduled or manual workflow run.")">
                            @(configuration.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                }
            </div>
        </section>
    }
    </div>
</section>
