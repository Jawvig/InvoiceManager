@model InvoiceManager.AdminWeb.Pages.Configurations.ConfigurationFormPageModel
<div asp-validation-summary="All" class="notice warning"></div>
@foreach (var warning in Model.DiscoveryWarnings) { <div class="notice warning">@warning</div> }
<input asp-for="Input.ETag" type="hidden" />
<input asp-for="Input.OriginalBillingAccountId" type="hidden" />
<input asp-for="Input.OriginalFolderItemId" type="hidden" />
<input asp-for="Input.OriginalDriveId" type="hidden" />
<input asp-for="Input.OriginalDisplayPath" type="hidden" />
@if (Model.IsEdit) { <input asp-for="Input.IntegrationType" type="hidden" /> }
<div class="form-grid">
    <label>Configuration ID <input asp-for="Input.Id" readonly="@Model.IsEdit" /></label>
    <label>Integration
        <select asp-for="Input.IntegrationType" disabled="@Model.IsEdit">
            <option value="Microsoft365">Microsoft 365</option><option value="Azure">Azure</option>
        </select>
    </label>
    <label>Invoice description <input asp-for="Input.InvoiceDescription" /></label>
    <label>Frequency <select asp-for="Input.Frequency"><option value="Monthly">Monthly</option></select></label>
    <label><input asp-for="Input.HasExpectedAmount" /> Match expected amount</label>
    <label>Expected amount <input asp-for="Input.ExpectedAmount" type="number" step="0.01" /></label>
    <label>ISO 4217 currency <input asp-for="Input.Currency" maxlength="3" /></label>
    <label>Amount tolerance <input asp-for="Input.AmountTolerance" type="number" min="0" step="0.01" /></label>
    <label>Default VAT mode <select asp-for="Input.DefaultVatMode"><option value="Inclusive">Inclusive</option><option value="Exclusive">Exclusive</option></select></label>
    <label>Start date <input asp-for="Input.StartDate" type="date" /></label>
    <p class="status-label">Changing the start date does not alter records already generated. After the first record, recurrence follows invoice history.</p>
    <label>Billing account
        <select asp-for="Input.BillingAccountId">
            @foreach (var account in Model.BillingAccounts) { <option value="@account.Id">@account.Label</option> }
            @if (Model.ShowMissingBillingWarning) { <option value="@Model.Input.OriginalBillingAccountId">Unavailable: @Model.Input.OriginalBillingAccountId</option> }
        </select>
    </label>
    <label>Date tolerance (days) <input asp-for="Input.DateToleranceDays" type="number" min="0" max="365" /></label>
    <label>Existing OneDrive folder
        <select asp-for="Input.FolderItemId">
            @foreach (var folder in Model.Folders) { <option value="@folder.Destination.FolderItemId">@folder.Destination.DisplayPath</option> }
            @if (Model.ShowMissingFolderWarning) { <option value="@Model.Input.OriginalFolderItemId">Unavailable: @Model.Input.OriginalDisplayPath</option> }
        </select>
    </label>
</div>
<button type="submit" class="primary-action">Save configuration</button>
<a asp-page="Index" class="secondary-action">Cancel</a>
