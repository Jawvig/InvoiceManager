<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-targeted so the Functions app can publish net10.0 to Flex Consumption; see
         InvoiceManager.Core.csproj for the rationale. -->
    <TargetFrameworks>net10.0;net11.0</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Cosmos SDK v3 has no NuGet dependency on Newtonsoft.Json but its core
         (DocumentClient) loads it at runtime regardless of the configured document
         serializer, so an explicit Newtonsoft.Json reference (below) is required or
         CosmosClient construction throws FileNotFoundException. That explicit reference
         also satisfies the SDK's build-time check, so the bypass flag is no longer needed. -->
    <AzureCosmosDisableNewtonsoftJsonCheck>true</AzureCosmosDisableNewtonsoftJsonCheck>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>InvoiceManager.Infrastructure.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" Version="1.21.0" />
    <PackageReference Include="Azure.Security.KeyVault.Secrets" Version="4.11.0" />
    <PackageReference Include="Microsoft.Azure.Cosmos" Version="3.61.0" />
    <!-- Standard resilience handler (Polly-based) for the Graph HttpClient: transient-fault
         and 429/503 throttling retry honouring Retry-After, with a bounded total timeout. -->
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" Version="10.6.0" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.8" />
    <PackageReference Include="Microsoft.Identity.Client" Version="4.85.2" />
    <!-- Required at runtime by the Cosmos SDK core; not pulled in transitively (see note above). -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\InvoiceManager.Core\InvoiceManager.Core.csproj" />
  </ItemGroup>

</Project>
